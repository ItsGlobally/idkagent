[Unit]
Description=idkagent Gateway Service
Documentation=https://github.com/itsglobally/idkagent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=%h/.local/bin/idkagent gateway start
Restart=on-failure
RestartSec=5
Environment=NODE_ENV=production
Environment=IDKAGENT_AS_SERVICE=1

[Install]
WantedBy=default.target
